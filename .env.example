# ---- The Knowles Files: environment ----
# Copy to ".env" for local runs. On GitHub Actions these are repo Secrets instead.

# Google AI Studio API key (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# YouTube OAuth. Get these by running scripts/auth_youtube.py once on your machine.
# Paste the FULL JSON contents (single line) of each file below, OR leave blank
# locally and keep the files token.json / client_secret.json next to the project.
YOUTUBE_TOKEN_JSON=
YOUTUBE_CLIENT_SECRET_JSON=

# Optional overrides (otherwise config.yaml wins)
# KNOWLES_PRIVACY=private          # private | unlisted | public
# KNOWLES_PUBLISH_AT=              # ISO8601 e.g. 2026-06-01T18:00:00Z (forces unlisted->scheduled)
